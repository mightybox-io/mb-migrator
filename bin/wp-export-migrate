#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
PROG_NAME="${MB_MIGRATOR_PROG_NAME:-$(basename "${BASH_SOURCE[0]}")}"

source "$ROOT_DIR/lib/util.sh"
source "$ROOT_DIR/lib/archive.sh"
source "$ROOT_DIR/lib/database.sh"
source "$ROOT_DIR/lib/wp-content.sh"
source "$ROOT_DIR/lib/wp-config.sh"
source "$ROOT_DIR/lib/wp-cli.sh"
source "$ROOT_DIR/providers/gridpane.sh"

COMMAND="${1:-}"
if [[ -n "$COMMAND" ]]; then
  shift
fi

usage() {
  cat <<'EOF' | sed "s/@@PROG@@/$PROG_NAME/g"
Usage:
  @@PROG@@ restore ARCHIVE.tar.gz --target-root=/srv/htdocs [options]

Options:
  --provider=auto|gridpane          Export provider adapter to use. Default: auto
  --target-root=PATH                WordPress document root to restore into
  --stage-dir=PATH                  Staging directory. Default: target-root/restore-<archive>-<timestamp>
  --db-output=PATH                  Combined SQL output path. Default: stage/<archive>-combined-phpmyadmin-import.sql
  --old-url=URL                     Old URL for WP-CLI search-replace
  --new-url=URL                     New URL for WP-CLI search-replace
  --dry-run                         Print planned file/DB actions without changing destination files
  --yes                             Answer yes to confirmation prompts
  --mu-plugins=ask|copy|skip        What to do with exported mu-plugins. Default: ask
  --include-mu-plugins              Alias for --mu-plugins=copy
  --root-extras=ask|copy|skip       What to do with non-core root files. Default: ask
  --replace-managed-symlinks        Replace destination symlink conflicts instead of preserving them
  --import-db                       Import the combined SQL using wp db import
  --skip-db-backup                  Do not run wp db export before --import-db
  --search-replace                  Run wp search-replace after DB import or against current DB
  --migrate-config                  After confirmation, replace target wp-config.php with exported wp-config.php
  --help                            Show this help

Examples:
  @@PROG@@ restore export.tar.gz --target-root=/srv/htdocs --dry-run

  @@PROG@@ restore export.tar.gz \
    --target-root=/srv/htdocs \
    --old-url=https://old.example.com \
    --new-url=https://new.example.com \
    --import-db --search-replace
EOF
}

if [[ "$COMMAND" == "--help" || "$COMMAND" == "-h" || -z "$COMMAND" ]]; then
  usage
  exit 0
fi

if [[ "$COMMAND" != "restore" ]]; then
  die "Unknown command: $COMMAND"
fi

ARCHIVE="${1:-}"
if [[ -z "$ARCHIVE" || "$ARCHIVE" == --* ]]; then
  die "restore requires an archive path"
fi
shift

PROVIDER="auto"
TARGET_ROOT=""
STAGE_DIR=""
DB_OUTPUT=""
OLD_URL=""
NEW_URL=""
DRY_RUN=0
ASSUME_YES=0
INCLUDE_MU_PLUGINS=0
MU_PLUGINS_MODE="ask"
ROOT_EXTRAS_MODE="ask"
REPLACE_MANAGED_SYMLINKS=0
IMPORT_DB=0
SKIP_DB_BACKUP=0
SEARCH_REPLACE=0
MIGRATE_CONFIG=0

while [[ $# -gt 0 ]]; do
  case "$1" in
    --provider=*) PROVIDER="${1#*=}" ;;
    --target-root=*) TARGET_ROOT="${1#*=}" ;;
    --stage-dir=*) STAGE_DIR="${1#*=}" ;;
    --db-output=*) DB_OUTPUT="${1#*=}" ;;
    --old-url=*) OLD_URL="${1#*=}" ;;
    --new-url=*) NEW_URL="${1#*=}" ;;
    --dry-run) DRY_RUN=1 ;;
    --yes) ASSUME_YES=1 ;;
    --mu-plugins=*) MU_PLUGINS_MODE="${1#*=}" ;;
    --include-mu-plugins) MU_PLUGINS_MODE="copy" ;;
    --root-extras=*) ROOT_EXTRAS_MODE="${1#*=}" ;;
    --replace-managed-symlinks) REPLACE_MANAGED_SYMLINKS=1 ;;
    --import-db) IMPORT_DB=1 ;;
    --skip-db-backup) SKIP_DB_BACKUP=1 ;;
    --search-replace) SEARCH_REPLACE=1 ;;
    --migrate-config) MIGRATE_CONFIG=1 ;;
    --help|-h) usage; exit 0 ;;
    *) die "Unknown option: $1" ;;
  esac
  shift
done

[[ -f "$ARCHIVE" ]] || die "Archive not found: $ARCHIVE"
[[ -n "$TARGET_ROOT" ]] || die "--target-root is required"
[[ -d "$TARGET_ROOT" ]] || die "Target root does not exist: $TARGET_ROOT"
case "$MU_PLUGINS_MODE" in ask|copy|skip) ;; *) die "--mu-plugins must be ask, copy, or skip" ;; esac
case "$ROOT_EXTRAS_MODE" in ask|copy|skip) ;; *) die "--root-extras must be ask, copy, or skip" ;; esac

need_cmd tar
need_cmd perl
need_cmd rsync

ARCHIVE="$(abs_path "$ARCHIVE")"
TARGET_ROOT="$(abs_path "$TARGET_ROOT")"

if [[ -z "$STAGE_DIR" ]]; then
  archive_base="$(basename "$ARCHIVE")"
  archive_base="${archive_base%.tar.gz}"
  archive_base="${archive_base%.tgz}"
  STAGE_DIR="$TARGET_ROOT/restore-${archive_base}-$(date +%Y%m%d%H%M%S)"
fi
STAGE_DIR="$(abs_path_for_create "$STAGE_DIR")"

mkdir -p "$STAGE_DIR"
REPORT_FILE="$STAGE_DIR/migration-report.txt"
: > "$REPORT_FILE"

log "Archive: $ARCHIVE"
log "Target root: $TARGET_ROOT"
log "Stage dir: $STAGE_DIR"
report "Archive: $ARCHIVE"
report "Target root: $TARGET_ROOT"
report "Stage dir: $STAGE_DIR"

archive_index "$ARCHIVE" "$STAGE_DIR"

case "$PROVIDER" in
  auto)
    if gridpane_detect "$ARCHIVE_INDEX"; then
      PROVIDER="gridpane"
    else
      die "Could not auto-detect export provider"
    fi
    ;;
  gridpane)
    gridpane_detect "$ARCHIVE_INDEX" || die "Archive does not look like a GridPane export"
    ;;
  *) die "Unsupported provider: $PROVIDER" ;;
esac

log "Provider: $PROVIDER"
report "Provider: $PROVIDER"

gridpane_load_layout "$ARCHIVE_INDEX"
gridpane_select_optional_paths "$MU_PLUGINS_MODE" "$ROOT_EXTRAS_MODE"
gridpane_extract "$ARCHIVE" "$STAGE_DIR" "$INCLUDE_MU_PLUGINS"

if [[ -z "$DB_OUTPUT" ]]; then
  archive_base="$(basename "$ARCHIVE")"
  archive_base="${archive_base%.tar.gz}"
  archive_base="${archive_base%.tgz}"
  DB_OUTPUT="$STAGE_DIR/${archive_base}-combined-phpmyadmin-import.sql"
fi

combine_database_sql "$STAGE_DIR/$GRIDPANE_DB_DIR" "$DB_OUTPUT"
verify_database_sql "$DB_OUTPUT"

merge_wp_content "$STAGE_DIR/$GRIDPANE_WEB_ROOT/wp-content" "$TARGET_ROOT/wp-content"
copy_web_root_files "$STAGE_DIR/$GRIDPANE_WEB_ROOT" "$TARGET_ROOT" "${GRIDPANE_ROOT_EXTRA_FILES[@]}"
wp_config_report "$STAGE_DIR/$GRIDPANE_WEB_ROOT/wp-config.php" "$TARGET_ROOT/wp-config.php" "$STAGE_DIR"

if [[ "$MIGRATE_CONFIG" -eq 1 ]]; then
  wp_config_migrate "$STAGE_DIR/$GRIDPANE_WEB_ROOT/wp-config.php" "$TARGET_ROOT/wp-config.php"
fi

if [[ "$IMPORT_DB" -eq 1 ]]; then
  wpcli_import_db "$TARGET_ROOT" "$DB_OUTPUT" "$SKIP_DB_BACKUP"
fi

if [[ "$SEARCH_REPLACE" -eq 1 ]]; then
  [[ -n "$OLD_URL" && -n "$NEW_URL" ]] || die "--search-replace requires --old-url and --new-url"
  wpcli_search_replace "$TARGET_ROOT" "$OLD_URL" "$NEW_URL"
fi

log "Done"
log "Combined SQL: $DB_OUTPUT"
log "Report: $REPORT_FILE"

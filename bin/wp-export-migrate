#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
PROG_NAME="${MB_MIGRATOR_PROG_NAME:-$(basename "${BASH_SOURCE[0]}")}"

source "$ROOT_DIR/lib/util.sh"
source "$ROOT_DIR/lib/archive.sh"
source "$ROOT_DIR/lib/database.sh"
source "$ROOT_DIR/lib/wp-content.sh"
source "$ROOT_DIR/lib/wp-config.sh"
source "$ROOT_DIR/lib/wp-cli.sh"
source "$ROOT_DIR/providers/gridpane.sh"

COMMAND="${1:-}"
if [[ -n "$COMMAND" ]]; then
  shift
fi

usage() {
  cat <<'EOF' | sed "s/@@PROG@@/$PROG_NAME/g"
Usage:
  @@PROG@@ restore ARCHIVE.tar.gz --target-root=/srv/htdocs [options]
  @@PROG@@ doctor --target-root=/srv/htdocs [--archive=ARCHIVE.tar.gz]

Options:
  --provider=auto|gridpane          Export provider adapter to use. Default: auto
  --target-root=PATH                WordPress document root to restore into
  --archive=PATH                    Archive path for doctor preflight checks
  --stage-dir=PATH                  Staging directory. Default: target-root/restore-<archive>-<timestamp>
  --db-output=PATH                  Combined SQL output path. Default: stage/<archive>-combined-phpmyadmin-import.sql
  --old-url=URL                     Old URL for WP-CLI search-replace
  --new-url=URL                     New URL for WP-CLI search-replace
  --dry-run                         Print planned file/DB actions without changing destination files
  --yes                             Answer yes to confirmation prompts
  --mu-plugins=ask|copy|skip        What to do with exported mu-plugins. Default: ask
  --include-mu-plugins              Alias for --mu-plugins=copy
  --root-extras=ask|copy|skip       What to do with non-core root files. Default: ask
  --replace-managed-symlinks        Replace destination symlink conflicts instead of preserving them
  --db-import=ask|yes|no            Import combined SQL with wp db import. Default: ask, default answer yes
  --import-db                       Alias for --db-import=yes
  --no-import-db                    Alias for --db-import=no
  --skip-db-backup                  Do not run wp db export before database import
  --cleanup=ask|yes|no              Delete migration artifacts after success. Default: ask
  --delete-sql-after-import         Legacy alias for --cleanup=yes
  --delete-stage-after-success      Legacy alias for --cleanup=yes
  --delete-archive-after-success    Legacy alias for --cleanup=yes
  --search-replace                  Run wp search-replace after DB import or against current DB
  --migrate-config                  After confirmation, replace target wp-config.php with exported wp-config.php
  --help                            Show this help

Examples:
  @@PROG@@ restore export.tar.gz --target-root=/srv/htdocs --dry-run

  @@PROG@@ restore export.tar.gz \
    --target-root=/srv/htdocs \
    --old-url=https://old.example.com \
    --new-url=https://new.example.com \
    --db-import=yes --search-replace
EOF
}

if [[ "$COMMAND" == "--help" || "$COMMAND" == "-h" || -z "$COMMAND" ]]; then
  usage
  exit 0
fi

if [[ "$COMMAND" == "doctor" ]]; then
  TARGET_ROOT=""
  ARCHIVE=""
  IMPORT_DB=0
  SEARCH_REPLACE=0

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --target-root=*) TARGET_ROOT="${1#*=}" ;;
      --archive=*) ARCHIVE="${1#*=}" ;;
      --import-db) IMPORT_DB=1 ;;
      --search-replace) SEARCH_REPLACE=1 ;;
      --help|-h) usage; exit 0 ;;
      *) die "Unknown option for doctor: $1" ;;
    esac
    shift
  done

  [[ -n "$TARGET_ROOT" ]] || die "doctor requires --target-root"
  TARGET_ROOT="$(abs_path "$TARGET_ROOT")"
  if [[ -n "$ARCHIVE" ]]; then
    ARCHIVE="$(abs_path "$ARCHIVE")"
  fi
  preflight_environment "$TARGET_ROOT" "$ARCHIVE" "$IMPORT_DB" "$SEARCH_REPLACE"
  log "Doctor completed"
  exit 0
fi

if [[ "$COMMAND" != "restore" ]]; then
  die "Unknown command: $COMMAND"
fi

ARCHIVE="${1:-}"
if [[ -z "$ARCHIVE" || "$ARCHIVE" == --* ]]; then
  die "restore requires an archive path"
fi
shift

PROVIDER="auto"
TARGET_ROOT=""
STAGE_DIR=""
DB_OUTPUT=""
OLD_URL=""
NEW_URL=""
DRY_RUN=0
ASSUME_YES=0
INCLUDE_MU_PLUGINS=0
MU_PLUGINS_MODE="ask"
ROOT_EXTRAS_MODE="ask"
REPLACE_MANAGED_SYMLINKS=0
IMPORT_DB=0
DB_IMPORT_MODE="ask"
SKIP_DB_BACKUP=0
SEARCH_REPLACE=0
MIGRATE_CONFIG=0
CLEANUP_MODE="ask"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --provider=*) PROVIDER="${1#*=}" ;;
    --target-root=*) TARGET_ROOT="${1#*=}" ;;
    --stage-dir=*) STAGE_DIR="${1#*=}" ;;
    --db-output=*) DB_OUTPUT="${1#*=}" ;;
    --old-url=*) OLD_URL="${1#*=}" ;;
    --new-url=*) NEW_URL="${1#*=}" ;;
    --dry-run) DRY_RUN=1 ;;
    --yes) ASSUME_YES=1 ;;
    --mu-plugins=*) MU_PLUGINS_MODE="${1#*=}" ;;
    --include-mu-plugins) MU_PLUGINS_MODE="copy" ;;
    --root-extras=*) ROOT_EXTRAS_MODE="${1#*=}" ;;
    --replace-managed-symlinks) REPLACE_MANAGED_SYMLINKS=1 ;;
    --db-import=*) DB_IMPORT_MODE="${1#*=}" ;;
    --import-db) DB_IMPORT_MODE="yes" ;;
    --no-import-db|--skip-db-import) DB_IMPORT_MODE="no" ;;
    --skip-db-backup) SKIP_DB_BACKUP=1 ;;
    --cleanup=*) CLEANUP_MODE="${1#*=}" ;;
    --delete-sql-after-import|--delete-stage-after-success|--delete-archive-after-success) CLEANUP_MODE="yes" ;;
    --search-replace) SEARCH_REPLACE=1 ;;
    --migrate-config) MIGRATE_CONFIG=1 ;;
    --help|-h) usage; exit 0 ;;
    *) die "Unknown option: $1" ;;
  esac
  shift
done

[[ -f "$ARCHIVE" ]] || die "Archive not found: $ARCHIVE"
[[ -n "$TARGET_ROOT" ]] || die "--target-root is required"
[[ -d "$TARGET_ROOT" ]] || die "Target root does not exist: $TARGET_ROOT"
case "$MU_PLUGINS_MODE" in ask|copy|skip) ;; *) die "--mu-plugins must be ask, copy, or skip" ;; esac
case "$ROOT_EXTRAS_MODE" in ask|copy|skip) ;; *) die "--root-extras must be ask, copy, or skip" ;; esac
case "$DB_IMPORT_MODE" in ask|yes|no) ;; *) die "--db-import must be ask, yes, or no" ;; esac
case "$CLEANUP_MODE" in ask|yes|no) ;; *) die "--cleanup must be ask, yes, or no" ;; esac
if [[ "$DB_IMPORT_MODE" != "no" && "$DRY_RUN" -ne 1 ]]; then
  IMPORT_DB=1
fi

need_cmd tar
need_cmd perl
need_cmd rsync
need_cmd grep
need_cmd sed
need_cmd awk
need_cmd find
need_cmd sort
need_cmd comm
need_cmd diff
need_cmd date
need_cmd head

ARCHIVE="$(abs_path "$ARCHIVE")"
TARGET_ROOT="$(abs_path "$TARGET_ROOT")"

if [[ -z "$STAGE_DIR" ]]; then
  archive_base="$(basename "$ARCHIVE")"
  archive_base="${archive_base%.tar.gz}"
  archive_base="${archive_base%.tgz}"
  STAGE_DIR="$TARGET_ROOT/restore-${archive_base}-$(date +%Y%m%d%H%M%S)"
fi
STAGE_DIR="$(abs_path_for_create "$STAGE_DIR")"

mkdir -p "$STAGE_DIR"
REPORT_FILE="$STAGE_DIR/migration-report.txt"
: > "$REPORT_FILE"

log "Archive: $ARCHIVE"
log "Target root: $TARGET_ROOT"
log "Stage dir: $STAGE_DIR"
report "Archive: $ARCHIVE"
report "Target root: $TARGET_ROOT"
report "Stage dir: $STAGE_DIR"

preflight_environment "$TARGET_ROOT" "$ARCHIVE" "$IMPORT_DB" "$SEARCH_REPLACE"

archive_index "$ARCHIVE" "$STAGE_DIR"

case "$PROVIDER" in
  auto)
    if gridpane_detect "$ARCHIVE_INDEX"; then
      PROVIDER="gridpane"
    else
      die "Could not auto-detect export provider"
    fi
    ;;
  gridpane)
    gridpane_detect "$ARCHIVE_INDEX" || die "Archive does not look like a GridPane export"
    ;;
  *) die "Unsupported provider: $PROVIDER" ;;
esac

log "Provider: $PROVIDER"
report "Provider: $PROVIDER"

log "Reading provider layout"
gridpane_load_layout "$ARCHIVE_INDEX"
log "Selecting optional paths"
gridpane_select_optional_paths "$MU_PLUGINS_MODE" "$ROOT_EXTRAS_MODE"
log "Extracting provider paths"
gridpane_extract "$ARCHIVE" "$STAGE_DIR" "$INCLUDE_MU_PLUGINS"

if [[ -z "$DB_OUTPUT" ]]; then
  archive_base="$(basename "$ARCHIVE")"
  archive_base="${archive_base%.tar.gz}"
  archive_base="${archive_base%.tgz}"
  DB_OUTPUT="$STAGE_DIR/${archive_base}-combined-phpmyadmin-import.sql"
fi

combine_database_sql "$STAGE_DIR/$GRIDPANE_DB_DIR" "$DB_OUTPUT"
verify_database_sql "$DB_OUTPUT"

merge_wp_content "$STAGE_DIR/$GRIDPANE_WEB_ROOT/wp-content" "$TARGET_ROOT/wp-content"
copy_web_root_files "$STAGE_DIR/$GRIDPANE_WEB_ROOT" "$TARGET_ROOT" "${GRIDPANE_ROOT_EXTRA_FILES[@]}"
SOURCE_WP_CONFIG=""
SOURCE_USER_CONFIGS=""
if [[ -n "${GRIDPANE_WP_CONFIG_PATH:-}" ]]; then
  SOURCE_WP_CONFIG="$STAGE_DIR/$GRIDPANE_WP_CONFIG_PATH"
fi
if [[ -n "${GRIDPANE_USER_CONFIGS_PATH:-}" ]]; then
  SOURCE_USER_CONFIGS="$STAGE_DIR/$GRIDPANE_USER_CONFIGS_PATH"
fi
wp_config_report "$SOURCE_WP_CONFIG" "$TARGET_ROOT/wp-config.php" "$STAGE_DIR"
wp_config_report_named "user-configs.php" "$SOURCE_USER_CONFIGS" "$TARGET_ROOT/user-configs.php" "$STAGE_DIR" "user-configs"

if [[ "$MIGRATE_CONFIG" -eq 1 ]]; then
  wp_config_migrate "$SOURCE_WP_CONFIG" "$TARGET_ROOT/wp-config.php"
  if [[ -n "$SOURCE_USER_CONFIGS" && -f "$SOURCE_USER_CONFIGS" ]]; then
    wp_config_migrate_named "user-configs.php" "$SOURCE_USER_CONFIGS" "$TARGET_ROOT/user-configs.php"
  fi
fi

wpcli_maybe_import_db "$TARGET_ROOT" "$DB_OUTPUT" "$SKIP_DB_BACKUP" "$DB_IMPORT_MODE" 0

if [[ "$SEARCH_REPLACE" -eq 1 ]]; then
  [[ -n "$OLD_URL" && -n "$NEW_URL" ]] || die "--search-replace requires --old-url and --new-url"
  wpcli_search_replace "$TARGET_ROOT" "$OLD_URL" "$NEW_URL"
fi

FINAL_REPORT_FILE="$REPORT_FILE"
CLEANUP_RAN=0
CLEANUP_HAS_ITEMS=0

cleanup_show_plan() {
  log "Cleanup would delete these migration artifacts:"
  if [[ -e "$ARCHIVE" ]]; then
    log "- Source export archive: $ARCHIVE"
    CLEANUP_HAS_ITEMS=1
  fi
  if [[ -d "$STAGE_DIR" ]]; then
    log "- Staging directory, including extracted files and generated artifacts: $STAGE_DIR"
    CLEANUP_HAS_ITEMS=1
  fi
  case "$DB_OUTPUT" in
    "$STAGE_DIR"/*) ;;
    *)
      if [[ -e "$DB_OUTPUT" ]]; then
        log "- Combined SQL file: $DB_OUTPUT"
        CLEANUP_HAS_ITEMS=1
      fi
      ;;
  esac
  if [[ -f "$REPORT_FILE" && -d "$STAGE_DIR" ]]; then
    log "A copy of the migration report will be preserved in: $TARGET_ROOT"
  fi
}

cleanup_run() {
  if [[ -f "$REPORT_FILE" && -d "$STAGE_DIR" ]]; then
    FINAL_REPORT_FILE="$TARGET_ROOT/mb-migrator-report-$(date +%Y%m%d%H%M%S).txt"
    cp "$REPORT_FILE" "$FINAL_REPORT_FILE"
    log "Preserved migration report: $FINAL_REPORT_FILE"
  fi

  case "$DB_OUTPUT" in
    "$STAGE_DIR"/*) ;;
    *)
      if [[ -e "$DB_OUTPUT" ]]; then
        log "Deleting combined SQL file: $DB_OUTPUT"
        rm -f "$DB_OUTPUT"
        report "Deleted combined SQL file: $DB_OUTPUT"
      fi
      ;;
  esac

  if [[ -d "$STAGE_DIR" ]]; then
    log "Deleting staging directory: $STAGE_DIR"
    rm -rf "$STAGE_DIR"
  fi

  if [[ -e "$ARCHIVE" ]]; then
    log "Deleting source export archive: $ARCHIVE"
    rm -f "$ARCHIVE"
  fi

  CLEANUP_RAN=1
}

if [[ "$CLEANUP_MODE" != "no" ]]; then
  if [[ "$DRY_RUN" -eq 1 ]]; then
    cleanup_show_plan
    if [[ "$CLEANUP_HAS_ITEMS" -eq 1 ]]; then
      log "Would ask whether to delete these cleanup items after a successful run"
    else
      log "No migration cleanup items found"
    fi
  else
    cleanup_show_plan
    if [[ "$CLEANUP_HAS_ITEMS" -eq 1 ]]; then
      if [[ "$CLEANUP_MODE" == "yes" ]] || confirm "Delete the migration artifacts listed above?"; then
        cleanup_run
      else
        log "Skipping cleanup; migration artifacts were left in place"
        report "Cleanup skipped by user"
      fi
    else
      log "No migration cleanup items found"
    fi
  fi
else
  log "Cleanup disabled; migration artifacts were left in place"
  report "Cleanup disabled"
fi

log "Done"
if [[ "$CLEANUP_RAN" -eq 1 ]]; then
  log "Staging directory deleted: $STAGE_DIR"
else
  log "Combined SQL: $DB_OUTPUT"
fi
log "Report: $FINAL_REPORT_FILE"
